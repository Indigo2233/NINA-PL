<UserControl x:Class="NINA.PL.WPF.Views.EquipmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
            <TextBlock DockPanel.Dock="Left" Text="EQUIPMENT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Primary}" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="Refresh all" Command="{Binding RefreshAllCommand}" Style="{StaticResource AccentActionButtonStyle}" Padding="16,8"/>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="CAMERA">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableCameras}" SelectedItem="{Binding SelectedCamera}"
                                          DisplayMemberPath="Name" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Settings" Command="{Binding OpenCameraSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Refresh" Command="{Binding RefreshCamerasCommand}" Margin="0,0,8,0"/>
                                    <Button Command="{Binding ToggleCameraConnectionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCameraConnected}" Value="True">
                                                        <Setter Property="Content" Value="Disconnect"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCameraConnected}" Value="False">
                                                        <Setter Property="Content" Value="Connect"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,16,0,0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding CameraStatus}" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock Text="Sensor &amp; color" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding CameraSensorSummary}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="Supported formats" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}" Margin="0,8,0,8"/>
                                <TextBlock Text="{Binding CameraFormatsSummary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="MOUNT">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding AvailableMounts}" SelectedItem="{Binding SelectedMount}"
                                          DisplayMemberPath="Name" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Settings" Command="{Binding OpenMountSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Refresh" Command="{Binding RefreshMountsCommand}" Margin="0,0,8,0"/>
                                    <Button Command="{Binding ToggleMountConnectionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMountConnected}" Value="True">
                                                        <Setter Property="Content" Value="Disconnect"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMountConnected}" Value="False">
                                                        <Setter Property="Content" Value="Connect"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,16,0,0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding MountStatus}" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,16"/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,8">
                                    <TextBlock Text="Right ascension (h)" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                    <TextBlock Text="{Binding MountRightAscensionHours, StringFormat=F4}" FontSize="16"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="Declination (°)" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                    <TextBlock Text="{Binding MountDeclinationDegrees, StringFormat=F4}" FontSize="16"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Altitude / Azimuth (°)" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                    <TextBlock FontSize="14">
                                        <Run Text="{Binding MountAltitudeDegrees, StringFormat=F2}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding MountAzimuthDegrees, StringFormat=F2}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="Tracking" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                    <TextBlock Text="{Binding MountIsTracking}" FontSize="14"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="FOCUSER">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding AvailableFocusers}" SelectedItem="{Binding SelectedFocuser}"
                                          DisplayMemberPath="Name" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Settings" Command="{Binding OpenFocuserSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Refresh" Command="{Binding RefreshFocusersCommand}" Margin="0,0,8,0"/>
                                    <Button Command="{Binding ToggleFocuserConnectionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFocuserConnected}" Value="True">
                                                        <Setter Property="Content" Value="Disconnect"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFocuserConnected}" Value="False">
                                                        <Setter Property="Content" Value="Connect"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,16,0,0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding FocuserStatus}" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,12"/>
                                <UniformGrid Columns="3" Margin="0,0,0,16">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Position" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                        <TextBlock FontSize="18">
                                            <Run Text="{Binding FocuserPosition}"/>
                                            <Run Text="/" Foreground="{StaticResource Brush.TextSecondary}"/>
                                            <Run Text="{Binding FocuserMaxPosition}" Foreground="{StaticResource Brush.TextSecondary}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Temperature (°C)" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                        <TextBlock Text="{Binding FocuserTemperature, StringFormat=F2}" FontSize="18"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Moving" FontSize="10" Foreground="{StaticResource Brush.TextSecondary}"/>
                                        <TextBlock Text="{Binding FocuserIsMoving}" FontSize="18"/>
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Text="Manual move" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="&lt;&lt;" Command="{Binding FocuserJogCommand}" CommandParameter="-500" Width="44" Margin="0,0,8,0"/>
                                    <Button Content="&lt;" Command="{Binding FocuserJogCommand}" CommandParameter="-50" Width="44" Margin="0,0,8,0"/>
                                    <Border Background="{StaticResource Brush.InputBg}" CornerRadius="3" Padding="12,8" MinWidth="72" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FocuserPosition}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                    <Button Content="&gt;" Command="{Binding FocuserJogCommand}" CommandParameter="50" Width="44" Margin="0,0,8,0"/>
                                    <Button Content="&gt;&gt;" Command="{Binding FocuserJogCommand}" CommandParameter="500" Width="44"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Target" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Brush.TextSecondary}"/>
                                    <TextBox Width="100" Text="{Binding FocuserTargetPosition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Content="Go" Command="{Binding MoveFocuserToTargetCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="FILTER WHEEL">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding AvailableFilterWheels}" SelectedItem="{Binding SelectedFilterWheel}"
                                          DisplayMemberPath="Name" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Settings" Command="{Binding OpenFilterWheelSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Refresh" Command="{Binding RefreshFilterWheelsCommand}" Margin="0,0,8,0"/>
                                    <Button Command="{Binding ToggleFilterWheelConnectionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFilterWheelConnected}" Value="True">
                                                        <Setter Property="Content" Value="Disconnect"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFilterWheelConnected}" Value="False">
                                                        <Setter Property="Content" Value="Connect"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,16,0,0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding FilterWheelStatus}" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,12"/>
                                <TextBlock Text="Current filter" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding CurrentFilterName}" FontSize="18" Margin="0,0,0,16"/>
                                <DataGrid ItemsSource="{Binding FilterSlots}" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" CanUserAddRows="False" MaxHeight="320">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsCurrent}" Width="70"/>
                                        <DataGridTemplateColumn Header="" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Select" Padding="8,4"
                                                            Command="{Binding DataContext.SelectFilterSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Index}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
