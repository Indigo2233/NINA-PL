<Window x:Class="NINA.PL.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:NINA.PL.WPF.ViewModels"
        xmlns:views="clr-namespace:NINA.PL.WPF.Views"
        Title="NINA-PL"
        Height="920" Width="1440"
        MinHeight="680" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource Brush.Background}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:EquipmentViewModel}">
            <views:EquipmentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CaptureViewModel}">
            <views:CaptureView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FocusViewModel}">
            <views:FocusView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GuiderViewModel}">
            <views:GuiderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveStackViewModel}">
            <views:LiveStackView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SequencerPanelViewModel}">
            <views:SequencerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsPanelViewModel}">
            <views:SettingsView/>
        </DataTemplate>

        <Style x:Key="SidebarNavButtonBase" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBd" Background="Transparent" BorderThickness="3,0,0,0" BorderBrush="Transparent" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBd" Property="Background" Value="{StaticResource Brush.SurfaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBd" Property="Background" Value="#FF252530"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.Sidebar}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="3" Background="#FF2A3540" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="PL" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Primary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NINA-PL" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock Text="Planetary" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"
                               Foreground="{StaticResource Brush.TextSecondary}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="—" Width="46" Height="32" Click="Minimize_Click" ToolTip="Minimize"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush.Text}" FontSize="14"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="□" Width="46" Height="32" Click="MaximizeRestore_Click" ToolTip="Maximize"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush.Text}" FontSize="12"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="✕" Width="46" Height="32" Click="Close_Click" ToolTip="Close"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush.Text}" FontSize="12"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Brush.Sidebar}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Equipment}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Equipment}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="⚙" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Equip" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Capture}" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Capture}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="📷" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Capture" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Focus}" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Focus}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="🎯" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Focus" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Guider}" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Guider}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="🔭" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Guider" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.LiveStack}" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.LiveStack}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="📚" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stack" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="6,16" Background="{StaticResource Brush.BorderSubtle}"/>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Sequencer}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Sequencer}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Seq" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:SidebarSection.Settings}" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static vm:SidebarSection.Settings}">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource Brush.Surface}" BorderThickness="3,0,0,0"
                                                            BorderBrush="{StaticResource Brush.Primary}" Padding="2,0,0,0" CornerRadius="0,3,3,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Set" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <ContentControl Grid.Column="1"
                            Margin="16,16,16,8"
                            Content="{Binding CurrentContent}"/>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource Brush.Sidebar}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="12,8">
            <TextBlock Text="{Binding StatusBarText}"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
